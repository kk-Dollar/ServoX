<?xml version="1.0" ?>
<robot name="servox" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find servox_description)/urdf/materials.xacro" />
<xacro:include filename="$(find servox_description)/urdf/servox.ros2control" />
<xacro:include filename="$(find servox_description)/urdf/servox.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="2.0104246875423716e-17 0.0 0.0025000000000000005" rpy="0 0 0"/>
    <mass value="0.4439070419522376"/>
    <inertia ixx="0.0004" iyy="0.0004" izz="0.000799" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find servox_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find servox_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

