  <inertial>
    <origin xyz="0.006673073283405578 -0.009075346203872573 0.0025000000000000022" rpy="0 0 0"/>
    <mass value="0.01673818232709913"/>
    <inertia ixx="2e-06" iyy="1e-06" izz="3e-06" ixy="1e-06" iyz="0.0" ixz="0.0"/>
