<joint name="base_joint" type="revolute">
  <origin xyz="0.0 0.0 0.005" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="shoulder_link_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit upper="1.5708" lower="-1.5708" effort="100" velocity="100"/>
</joint>

<joint name="shoulder_joint" type="revolute">
  <origin xyz="0.00023 0.0176 0.034783" rpy="0 0 0"/>
  <parent link="shoulder_link_1"/>
  <child link="upper_arm_link_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <limit upper="0.785398" lower="0.0" effort="100" velocity="100"/>
</joint>

<joint name="elbow_joint" type="revolute">
  <origin xyz="-0.00023 0.0001 0.110217" rpy="0 0 0"/>
  <parent link="upper_arm_link_1"/>
  <child link="fore_arm_link_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit upper="1.396263" lower="-0.785398" effort="100" velocity="100"/>
</joint>

<joint name="wrist_left_joint" type="revolute">
  <origin xyz="0.085077 -0.006181 0.0076" rpy="0 0 0"/>
  <parent link="fore_arm_link_1"/>
  <child link="left_gripper_link_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit upper="0.0" lower="-0.85" effort="100" velocity="100"/>
  <mimic joint="wrist_right_joint" multiplier="-1" offset="0"/>
</joint>

<joint name="wrist_right_joint" type="revolute">
  <origin xyz="0.084915 -0.02422 0.0076" rpy="0 0 0"/>
  <parent link="fore_arm_link_1"/>
  <child link="right_gripper_link_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit upper="0.85" lower="0.00" effort="100" velocity="100"/>
  
</joint>

</robot>
