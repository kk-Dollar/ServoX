<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="servox">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import servox urdf file -->
    <xacro:include filename="$(find servox_description)/urdf/servox.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="servox.ros2_control.xacro" />


    <xacro:servox_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
